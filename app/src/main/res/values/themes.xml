<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- AppCompat-compatible theme required because MainActivity uses AppCompatDelegate APIs. -->
    <style name="Theme.ImageTools" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Backward alias to avoid breaking any existing references. -->
    <style name="Theme.Image" parent="Theme.ImageTools" />

    <!-- View-based image editor: dark surfaces + accent aligned with Compose ImageDesign -->
    <style name="Theme.Image.Editor" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/editor_canvas</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorPrimary">@color/editor_accent</item>
        <item name="colorOnPrimary">@color/editor_on_accent</item>
        <item name="colorSurface">@color/editor_surface</item>
        <item name="colorOnSurface">@color/editor_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/editor_on_surface_muted</item>
        <item name="colorOutline">@color/editor_outline</item>
        <item name="colorControlNormal">#AEB6C2</item>
        <item name="colorControlActivated">#3794FF</item>
    </style>

    <style name="Widget.Image.Editor.ToolButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/editor_outline</item>
        <item name="android:textColor">@color/editor_on_surface</item>
    </style>

    <style name="TransparentBottomSheetDialog" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/TransparentBottomSheetStyle</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
</resources>
